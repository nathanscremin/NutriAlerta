# ============================================================
# Configurações da API - SISVAN Estado Nutricional
# Copie para .env
# ============================================================

API_BASE_URL=https://apidadosabertos.saude.gov.br

UF_FILTRO=SP
CODIGO_MUNICIPIO=354390

IDADE_MINIMA=0
IDADE_MAXIMA=18

# Fases de vida (0–18 anos): 1 a 6 = criança/adolescente
# 1=MENOR DE 6 MESES, 2=6M-2A, 3=2-5A, 4=5-7A, 5=7-10A, 6=ADOLESCENTE
FASES_VIDA=1,2,3,4,5,6

# URL modelo:
# .../estado-nutricional?codigo_municipio=354390&uf=SP
# &idade_minima=0&idade_maxima=0&codigo_fase_vida=1&limit=100&offset=0
LIMIT_POR_PAGINA=100

# 2 = faixas 0–1, 2–3, … | 1 = uma idade por vez (como na URL de exemplo)
ANOS_POR_FAIXA=2

PAUSA_ENTRE_REQUISICOES=0.5
