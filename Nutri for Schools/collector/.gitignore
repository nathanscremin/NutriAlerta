# Ambiente virtual Python
venv/
.venv/
env/

# Credenciais (nunca versionar)
.env

# Dados brutos e processados (grandes demais para o Git; mantém .gitkeep)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/state.json

# Cache do Python
__pycache__/
*.py[cod]
*.pyo

# IDEs
.vscode/
.idea/
*.code-workspace

# Logs
*.log

# Sistema operacional
.DS_Store
Thumbs.db
